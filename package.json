{
  "name": "universal-credit-assessment-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "lha:import": "node scripts/import-lha-rates.ts",
    "postcode:import": "node scripts/postcode_lookup_importer.ts",
    "worker:dev": "wrangler dev src/workers/api/index.ts",
    "db:migrate:local": "wrangler d1 migrations apply uc_assessments --local"
  },
  "dependencies": {
    "@hookform/resolvers": "latest",
    "@react-pdf/renderer": "latest",
    "@tailwindcss/postcss": "latest",
    "@vitejs/plugin-react": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "latest",
    "tailwind-merge": "latest",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
